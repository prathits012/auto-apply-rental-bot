# Copy this to .env for local development
# Set these as Variables in Railway for production

# ── Required ──────────────────────────────────────────────────
EMAIL_FROM=your.gmail@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=your.gmail@gmail.com,other@gmail.com

# ── Optional (defaults shown) ─────────────────────────────────
GOOGLE_MAPS_API_KEY=
SEARCH_CENTER_LAT=37.7764
SEARCH_CENTER_LNG=-122.3947
SEARCH_RADIUS_MILES=0.5
FILTER_MIN_PRICE=2500
FILTER_MAX_PRICE=4500
FILTER_MIN_BEDS=1
FILTER_MAX_BEDS=2
FILTER_MIN_BATHS=1
MAX_LISTING_AGE_HOURS=24
CONFIRM_TIMEOUT_MINUTES=15
USE_LLM=false
APPLICANT_PROFILE=Software engineer, no pets, non-smoker, stable income, flexible move-in date
